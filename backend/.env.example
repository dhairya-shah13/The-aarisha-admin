# ── Aarisha Admin Backend — Environment Variables ──
# Copy this to .env and fill in your values.

# Supabase project URL (e.g., https://your-project.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service_role key (from Project Settings -> API -> service_role key)
# NEVER expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key

# JWT secret for signing tokens (generate a random string)
JWT_SECRET=generate-a-long-random-secret

# Admin credentials
ADMIN_EMAIL=admin@aarisha.com
# Generate with: python generate_password_hash.py
ADMIN_PASSWORD_HASH=$2b$12$replace_with_a_bcrypt_hash

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://the-aarisha-admin.vercel.app

# JWT token expiry in minutes
JWT_MINUTES=30
